# Database (Railway configura automaticamente DATABASE_URL quando você adiciona PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Secret (use uma string aleatória longa em produção)
JWT_SECRET=sua-chave-secreta-aqui

# Resend API (para envio de emails)
RESEND_API_KEY=re_xxxxxxxxxxxx

# URL da aplicação em produção
APP_URL=https://seu-app.up.railway.app

# Email de envio (após verificar domínio no Resend)
FROM_EMAIL=noreply@seudominio.com.br

# Porta (Railway define automaticamente)
PORT=3000
